{
  "Name": "orthanc-s3",
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": false,
  "StorageDirectory": "OrthancStorage", 
  "IndexDirectory": "OrthancStorage",
  "DicomServerEnabled": true,
  "DicomAet": "ORTHANC",
  "DicomPort": 4242,
  "DicomModalitiesInDatabase" : true,
  "Plugins": ["/usr/share/orthanc/plugins/"],
  "ConcurrentJobs": 4,
  "JobsHistorySize": 1000,
  "LimitJobs": 100,
  "HttpTimeout": 240,
  "DicomScpTimeout": 60,
  "S3": {
    "aws_access_key_id": "jupyter",
    "aws_secret_access_key": "jupyter@analytics",
    "aws_region": "us-east-1",
    "s3_endpoint": "http://object-storage:9000",
    "s3_bucket": "images",
    "implementation": "transfer_manager"
  },
  "AwsS3Storage": {
    "AccessKey": "jupyter",
    "SecretKey": "jupyter@analytics",
    "Region": "us-east-1",
    "Endpoint": "http://object-storage:9000",
    "BucketName": "images",
    "VirtualAddressing": "false"
  },
  "PostgreSQL": {
    "EnableIndex": true,
    "EnableStorage": false,
    "Host": "orthanc-db",
    "Port": 5432,
    "Database": "images",
    "Username": "postgres",
    "Password": "images-meta@medical-db",
    "EnableSsl": false
  },
  "DicomWeb":{
    "Enable": true,
    "Root": "/dicom-web/",
    "EnableWado": true,
    "WadoRoot": "/wado",
    "StowMaxInstances": 10,
    "StowMaxSize": 10,
    "QidoCaseSensitive": false
  },
  "Authorization": {
    "WebService": "http://imaging:8070/auth/service/orthanc/dev01/introspect",
    "TokenHttpHeaders" : [ "Authorization", "Referer" ],
    "TokenGetArguments": ["api-auth", "api-token", "token", "authorization"]
  },
  "Sonador": {
    "SonadorUrl": "http://imaging:8070",
    "ApiToken": "secure-api@sonador-dev",
    "OrthancServerId": "dev01",
    "InternalDns": true,
    "Kafka": {
      "topic": "orthanc-index",
      "servers": ["kafka:9092"]
    }
  },
  "Dictionary": {
  }
}
