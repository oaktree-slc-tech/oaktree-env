[Site-Config]
SITE_ID = 1	# ID for the currently active site (primary key of the domain in the Django sites framework)
SITE_HAME = 'http://acorn.local'	# Domain of the website
SECRET_KEY = 'project secret key, used for encryption, should be long and very random'
INTERNAL_IPS = '*',
ALLOWED_HOSTS = '127.0.0.1', 'localhost', 'acorn.local', 'acorn', '*'
LOG_LEVEL_ROOT = 'DEBUG'	# Level of log detail: DEBUG, INFO, ERROR
LOG_LEVEL_CONSOLE = 'DEBUG'	# Level of log detail to output to console: DEBUG, INFO, ERROR

[Site-Connection]
SITE_CONNECT_SCHEME = 'http' # Site connection scheme (production)
SITE_CONNECT_PORT = '8080' # If different from http/https defaults (80/443)
SITE_CONNECT_SCHEME_DEVEL = 'http' # Connection connection scheme (development)
SITE_CONNECT_PORT_DEVEL = '8080' # Connection port (development)
BASE_URL = 'http://acorn:8080'

[Localization]
TIME_ZONE = 'America/Denver'
LANGUAGE_CODE = 'en-us'


[Databases]
[[default]]
ENGINE = 'django.db.backends.postgresql_psycopg2'
NAME = 'acorn'
USER = 'postgres'
PASSWORD = 'web-control@acorn'
HOST = 'acorn-db'
PORT =  '5432'


[Database-Migrations]
auth = dbmigrations.auth
wgtbase = dbmigrations.wgtbase
wgcontent = dbmigrations.wgtcontent
secure = dbmigrations.secure
wgtsocial = dbmigrations.wgtauth.social
wgtregistration = dbmigrations.wgtauth.registration
oaknut = dbmigrations.oaknut
flexforms = dbmigrations.flexforms
comments = dbmigrations.comments
hooks = dbmigrations.hooks



[Search]
[[default]]
'BACKEND' = 'wagtail.search.backends.database'

[Resource-Files]
STATIC_ROOT = '/srv/www/acorn.oak-tree.us/docroot/static'
MEDIA_ROOT = '/srv/www/acorn.oak-tree.us/docroot/media'


[Content-Management]
WAGTAIL_SITE_NAME = 'Oak-Tree Acorn'


[Storage]
OBJECT_STORAGE_TYPE = 's3-minio'


[S3]
AWS_S3_SERVICE_URL = 'http://object-storage:9000'
AWS_S3_ACCESS_ID = 'jupyter'
AWS_S3_SECRET_KEY = 'jupyter@analytics'
AWS_S3_CONTAINER = 'acorn-media'
AWS_S3_REGION = 'us-east-1'
AWS_S3_STATIC_CONTAINER = 'acorn-static'
AWS_S3_MEDIA_CONTAINER = 'acorn-media'



[Email]
EMAIL_SCHEME = ''
EMAIL_HOST = ''
EMAIL_PORT = ''
EMAIL_SITE_ACCESSID = ''
EMAIL_SECRET_KEY = ''


[GitLab-SSO]
GITLAB_SSO_ENABLED = False
GITLAB_AUTH_SCHEME = ''
GITLAB_AUTH_HOST = ''
GITLAB_AUTH_PORT = ''
GITLAB_AUTH_CLIENT_ID = ''
GITLAB_AUTH_CLIENT_SECRET = ''


[SAML]
SITE_SAML_ENABLED = False


